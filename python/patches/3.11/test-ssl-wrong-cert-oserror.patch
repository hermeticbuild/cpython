Backport the test_wrong_cert_tls13 expectation from CPython 3.13.

CPython commits ea9a296fce2f786b4cf43c7924e5de01061f27ca and
a214f55b274df9782e78e99516a372e0b800162a accept the OSError results that
can report a TLS 1.3 certificate rejection, including BrokenPipeError on
macOS.

diff --git a/Lib/test/test_ssl.py b/Lib/test/test_ssl.py
--- a/Lib/test/test_ssl.py
+++ b/Lib/test/test_ssl.py
@@ -3337,8 +3337,10 @@ class ThreadedTests(unittest.TestCase):
                                         suppress_ragged_eofs=False) as s:
             s.connect((HOST, server.port))
             with self.assertRaisesRegex(
-                ssl.SSLError,
-                'alert unknown ca|EOF occurred'
+                OSError,
+                'alert unknown ca|EOF occurred|TLSV1_ALERT_UNKNOWN_CA|'
+                'closed by the remote host|Connection reset by peer|'
+                'Broken pipe'
             ):
                 # TLS 1.3 perform client cert exchange after handshake
                 s.write(b'data')
